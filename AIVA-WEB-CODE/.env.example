# AIVA Production Environment Variables
# Copy this file to .env and fill in your actual values

NODE_ENV=production
PORT=5000

# MongoDB Atlas Connection String
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# JWT Secret (generate with: openssl rand -hex 64)
JWT_SECRET=your-super-secure-jwt-secret-here

# CORS Origin for production
CORS_ORIGIN=https://aiva.mohitrajsinh.me

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=15

# Email configuration (if needed)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Google Cloud Storage (if using GCS)
GCS_PROJECT_ID=your-gcp-project
GCS_BUCKET_NAME=your-bucket-name

# Google Drive API Configuration
GOOGLE_DRIVE_CREDENTIALS_PATH=./config/gcs-key.json
GOOGLE_DRIVE_FOLDER_ID=  # Optional: Specific folder ID for uploads
STORAGE_TYPE=gridfs  # Temporarily using GridFS until Drive API is enabled

# MinIO Configuration (alternative storage)
MINIO_ENDPOINT=minio
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# API Keys (keep secure!)
GEMINI_API_KEY=your-gemini-api-key-here
VITE_OPENAI_API_KEY=your-openai-api-key-here

# Client Configuration
CLIENT_URL=https://aiva.mohitrajsinh.me
VITE_APP_API_URL=https://aiva.mohitrajsinh.me