NODE_ENV=development
MONGO_URI=mongodb+srv://your_db_user:your_password@your_cluster.mongodb.net/your_db?retryWrites=true&w=majority&appName=your_app
PORT=5000
CORS_ORIGIN=http://localhost:3000
GMAIL_USER=your_email@gmail.com
GMAIL_PASS=your_app_password
CLIENT_URL=http://localhost:3000

# Google Cloud Platform Configuration
GCP_PROJECT_ID=your_gcp_project
GCS_BUCKET_NAME=your_bucket_name
GCS_KEY_FILE=./config/gcs-key.json

# Google Drive API Configuration
GOOGLE_DRIVE_CREDENTIALS_PATH=./config/gcs-key.json
GOOGLE_DRIVE_FOLDER_ID=
STORAGE_TYPE=gridfs

# MinIO Configuration (alternative storage)
MINIO_ENDPOINT=minio
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# JWT Configuration - Generate a secure random string
JWT_SECRET=your_secure_jwt_secret_here

GEMINI_API_KEY=your_gemini_api_key